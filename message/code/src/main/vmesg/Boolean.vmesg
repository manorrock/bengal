object Boolean {

  native {
    java.lang.Boolean booleanValue;
  }

  method true() {
    native {
      booleanValue = true;
    }
  }

  method false() {
    native {
      booleanValue = false;
    }
  }

  method and(value) {
    native {
      return this.booleanValue && value;
    }
  }
}
